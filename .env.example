# =============================================================================
# TransparencIA Indexer Configuration
# =============================================================================

# --- PostgreSQL (Supabase) ---
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:6543/postgres

# --- AT Protocol ---
ATPROTO_DID=did:plc:top57c5tklg2fjl66hpidi45

# --- Tap (AT Protocol sync) ---
TAP_BIND=:2480
TAP_RELAY_URL=https://bsky.network
TAP_COLLECTION_FILTERS=tech.transparencia.news.article,tech.transparencia.news.source,tech.transparencia.news.enrichment
TAP_DISABLE_ACKS=true
TAP_LOG_LEVEL=info
TAP_PORT=2480

# --- GraphQL ---
GRAPHQL_PORT=4000
# GRAPHQL_API_KEY=your-secret-key

# --- Indexer ---
TAP_WS_URL=ws://tap:2480/channel
