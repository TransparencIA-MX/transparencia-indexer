# =============================================================================
# TransparencIA Indexer Configuration
# =============================================================================

# --- PostgreSQL (Supabase) ---
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or use individual vars:
# PGHOST=aws-0-us-east-1.pooler.supabase.com
# PGPORT=6543
# PGDATABASE=postgres
# PGUSER=postgres.[project-ref]
# PGPASSWORD=your-password

# --- AT Protocol PDS ---
ATPROTO_PDS_URL=https://pds.transparencia.tech
ATPROTO_DID=did:plc:top57c5tklg2fjl66hpidi45

# --- Jetstream ---
# Public Jetstream relay (or self-hosted)
JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe
# Collections to index (comma-separated)
JETSTREAM_COLLECTIONS=tech.transparencia.news.article,tech.transparencia.news.source,tech.transparencia.news.enrichment

# --- GraphQL ---
GRAPHQL_PORT=4000
# Optional: API key for authenticated access
# GRAPHQL_API_KEY=your-secret-key
